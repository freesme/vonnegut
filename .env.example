# ============================================================
# Hot Stock 本地策略系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 数据源 ----------
# Tushare Pro token（可选，不填则使用 AKShare + 东方财富）
# 申请地址：https://tushare.pro/register
TUSHARE_TOKEN=

# ---------- 数据库 (PostgreSQL) ----------
POSTGRES_USER=hotstock
POSTGRES_PASSWORD=hotstock123
POSTGRES_DB=hotstock_cache
# Docker 内部使用 postgres 主机名；本地开发改为 localhost
DATABASE_URL=postgresql://hotstock:hotstock123@postgres:5432/hotstock_cache

# ---------- 通知推送 ----------
# 通知方式：console（终端打印）/ serverchan（微信）/ dingtalk（钉钉）
NOTIFY_BACKEND=console

# Server酱 SendKey（NOTIFY_BACKEND=serverchan 时必填）
# 申请地址：https://sct.ftqq.com/
SERVERCHAN_KEY=

# 钉钉群机器人 Webhook（NOTIFY_BACKEND=dingtalk 时必填）
DINGTALK_WEBHOOK=

# ---------- JWT 鉴权 ----------
# Token 签名密钥（生产环境务必修改）
JWT_SECRET_KEY=hotstock-dev-secret-change-me
# Token 过期时间（分钟，默认 1440 即 24 小时）
# JWT_EXPIRE_MINUTES=1440
