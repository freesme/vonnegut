# ============================================================
# Hot Stock 本地策略系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 数据源 ----------
# Tushare Pro token（可选，不填则使用 AKShare + 东方财富）
# 申请地址：https://tushare.pro/register
TUSHARE_TOKEN=

# ---------- 通知推送 ----------
# 通知方式：console（终端打印）/ serverchan（微信）/ dingtalk（钉钉）
NOTIFY_BACKEND=console

# Server酱 SendKey（NOTIFY_BACKEND=serverchan 时必填）
# 申请地址：https://sct.ftqq.com/
SERVERCHAN_KEY=

# 钉钉群机器人 Webhook（NOTIFY_BACKEND=dingtalk 时必填）
DINGTALK_WEBHOOK=
